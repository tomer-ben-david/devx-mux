{
  "name": "devx-mux",
  "version": "0.1.0",
  "description": "DevX Mux command-line interface",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomer-ben-david/devx-mux.git"
  },
  "homepage": "https://github.com/tomer-ben-david/devx-mux#readme",
  "bugs": {
    "url": "https://github.com/tomer-ben-david/devx-mux/issues"
  },
  "keywords": [
    "ai",
    "code-review",
    "codex",
    "grok",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "bin": {
    "mux": "dist/main.js"
  },
  "files": [
    "dist/main.js",
    "dist/main.js.map",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "node ../../scripts/prepare-npm-package.ts",
    "postpack": "node ../../scripts/cleanup-npm-package.ts",
    "test": "node --test --import=tsx 'src/**/*.test.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.4.3",
    "@opentui/react": "^0.4.3",
    "bun": "^1.3.14",
    "react": "^19.2.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsx": "^4.20.0"
  }
}
